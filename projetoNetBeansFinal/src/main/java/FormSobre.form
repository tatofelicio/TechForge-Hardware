      <SubComponents>
        <Component class="javax.swing.JTextArea" name="txtSobreNos">
          <Properties>
            <Property name="editable" type="boolean" value="false"/>
            <Property name="columns" type="int" value="20"/>
            <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
              <Font name="Unispace" size="14" style="0"/>
            </Property>
            <Property name="lineWrap" type="boolean" value="true"/>
            <Property name="rows" type="int" value="5"/>
            <Property name="text" type="java.lang.String" value="   A TechForge Hardware nasceu com o objetivo de oferecer solu&#xe7;&#xf5;es de qualidade para quem busca desempenho confian&#xe7;a e tecnologia.&#xa;&#xa;   Somos uma loja especializada em componentes e equipamentos de hardware trabalhando com produtos como processadores, placas de v&#xed;deo, mem&#xf3;rias RAM, perif&#xe9;ricos, acess&#xf3;rios e pe&#xe7;as essenciais para computadores.&#xa;&#xa;    Nosso compromisso &#xe9; atender cada cliente com responsabilidade, transpar&#xea;ncia e dedica&#xe7;&#xe3;o, ajudando na escolha dos melhores produtos de acordo com suas necessidades&#xa;&#xa;   Seja para montar um computador gamer, melhorar o desempenho de uma m&#xe1;quina,realizar manuten&#xe7;&#xe3;o ou atualizar equipamentos, a TechForge Hardware est&#xe1; pronta &#xa;&#xa;&quot;TechForge Hardware &#x2014; pot&#xea;ncia que conecta o futuro.&quot;"/>
            <Property name="wrapStyleWord" type="boolean" value="true"/>
          </Properties>
        </Component>
      </SubComponents>
    </Container>
